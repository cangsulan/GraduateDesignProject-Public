# ============================================================
# 全局环境变量配置文件
# 微服务场景下的异常流量检测系统
# ============================================================

# ---- 异常检测大屏系统 (Web前端) 登录凭证 ----
# 前端访问端口: 80 (或者映射到宿主机自定义的端口)
# 默认系统超管账号: admin
# 默认系统登录密码: 123456


# ---- MySQL 配置 ----
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=anomaly_detection
MYSQL_PORT=3306

# ---- Redis 配置 ----
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# ---- RabbitMQ 配置 ----
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=admin123
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# ---- Java 后端配置 ----
BACKEND_PORT=8080
JWT_SECRET=anomaly-detection-jwt-secret-key-2024

# ---- Python AI 引擎配置 ----
AI_ENGINE_PORT=8000

# ---- AI 引擎核心融合参数 ----
# FUSION_ALPHA 是随机森林(RF)模型和图神经网络(GCN)模型预测结果的融合权重。(RF 占比)
# 范围: 0.0 ~ 1.0 (例如 0.5 表示两者各占 50%)
# 如果您想更侧重于【请求特征/频率等】指标的检测，可以将其调高 (如 0.8)
# 如果您想更侧重于【微服务拓扑调用关系】的检测，可以将其调低 (如 0.2)
# 505组极限网格实验证明，双模态最终绝佳黄金权重点为 0.36
# 在该配比下与 Depth=2 的图网络融合，F1达到惊人的 0.9681 本地历史巅峰！
FUSION_ALPHA=0.36
